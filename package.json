{
  "name": "@vitalyostanin/gitlab-mcp",
  "version": "0.6.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/index.js && cp package.json dist/package.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "test": "timeout 600 vitest run",
    "test:watch": "vitest",
    "test:coverage": "timeout 600 vitest run --coverage",
    "format": "npm run --silent lint:fix",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm audit --omit=dev --audit-level=high && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gitlab",
    "devops",
    "merge-requests",
    "releases",
    "claude"
  ],
  "author": "Vitaly Ostanin <vitaly.ostanin@mail.ru>",
  "license": "MIT",
  "description": "GitLab MCP server for managing projects, merge requests, release tagging, and search via Model Context Protocol.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.12.1",
  "bin": {
    "gitlab-mcp": "dist/index.js"
  },
  "homepage": "https://github.com/VitalyOstanin/gitlab-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitalyOstanin/gitlab-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyOstanin/gitlab-mcp/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.json",
    "README.md",
    "README-ru.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitalyostanin/mutex-pool": "^0.0.3",
    "axios": "^1.18.1",
    "luxon": "^3.7.2",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.9"
  }
}
